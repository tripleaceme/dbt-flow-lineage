{
  "name": "dbt-flow-lineage",
  "displayName": "dbt Flow Lineage",
  "description": "Animated column-level lineage visualization for dbt projects",
  "version": "0.1.0",
  "publisher": "tripleaceme",
  "license": "MIT",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Visualization",
    "Data Science"
  ],
  "keywords": [
    "dbt",
    "lineage",
    "column-level",
    "data",
    "analytics"
  ],
  "activationEvents": [
    "workspaceContains:**/dbt_project.yml"
  ],
  "main": "./dist/extension.js",
  "icon": "media/icon.png",
  "contributes": {
    "commands": [
      {
        "command": "dbtFlowLineage.showLineage",
        "title": "dbt Flow: Show Column Lineage",
        "icon": "$(type-hierarchy)"
      },
      {
        "command": "dbtFlowLineage.showLineageForModel",
        "title": "dbt Flow: Show Lineage for Current Model"
      },
      {
        "command": "dbtFlowLineage.refresh",
        "title": "dbt Flow: Refresh Lineage Data",
        "icon": "$(refresh)"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "dbtFlowLineage",
          "title": "dbt Flow Lineage",
          "icon": "media/sidebar-icon.svg"
        }
      ]
    },
    "views": {
      "dbtFlowLineage": [
        {
          "id": "dbtFlowLineage.modelsTree",
          "name": "Models",
          "type": "tree"
        }
      ]
    },
    "menus": {
      "editor/title": [
        {
          "command": "dbtFlowLineage.showLineageForModel",
          "when": "resourceExtname == .sql",
          "group": "navigation"
        }
      ],
      "explorer/context": [
        {
          "command": "dbtFlowLineage.showLineageForModel",
          "when": "resourceExtname == .sql"
        }
      ],
      "view/title": [
        {
          "command": "dbtFlowLineage.refresh",
          "when": "view == dbtFlowLineage.modelsTree",
          "group": "navigation"
        }
      ]
    },
    "configuration": {
      "title": "dbt Flow Lineage",
      "properties": {
        "dbtFlowLineage.targetPath": {
          "type": "string",
          "default": "target",
          "description": "Relative path to dbt target directory"
        },
        "dbtFlowLineage.animationSpeed": {
          "type": "number",
          "default": 2,
          "minimum": 1,
          "maximum": 5,
          "description": "Particle animation speed (1=slow, 5=fast)"
        },
        "dbtFlowLineage.maxDepth": {
          "type": "number",
          "default": 10,
          "minimum": 1,
          "maximum": 50,
          "description": "Maximum upstream/downstream depth to render"
        },
        "dbtFlowLineage.showWelcomeOnStartup": {
          "type": "boolean",
          "default": true,
          "description": "Show welcome page on first activation"
        }
      }
    }
  },
  "scripts": {
    "build": "node esbuild.mjs",
    "watch": "node esbuild.mjs --watch",
    "package": "vsce package",
    "lint": "eslint src/ webview-ui/src/",
    "test": "vitest run"
  },
  "devDependencies": {
    "@types/d3": "^7.4.3",
    "@types/dagre": "^0.7.54",
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^2.22.0",
    "esbuild": "^0.20.0",
    "eslint": "^8.56.0",
    "typescript": "^5.3.3",
    "vitest": "^1.2.0"
  },
  "dependencies": {
    "d3": "^7.9.0",
    "dagre": "^0.8.5",
    "node-sql-parser": "^5.3.0"
  }
}
